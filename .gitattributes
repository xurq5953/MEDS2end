# Normalize text in the repository and keep source files LF-only for Win/WSL.
* text=auto

# C/C++ sources and headers
*.c text eol=lf
*.h text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf

# Build and project metadata
CMakeLists.txt text eol=lf
*.cmake text eol=lf
Makefile text eol=lf
*.mk text eol=lf

# Scripts and common text formats
*.sh text eol=lf
*.py text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Native Windows scripts keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.exe binary
*.dll binary
*.lib binary
*.a binary
*.so binary
*.dylib binary
